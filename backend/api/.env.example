APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Sitio estático NovaSalud (opcional). Ej.: http://localhost/ProyectoNuevo/frontend/index.html
# Si se omite y APP_URL termina en /backend/api/public, se deduce la ruta al frontend.
# FRONTEND_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local: sqlite (por defecto). Producción / servidor global: MySQL o MariaDB remoto.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=novasalud
# DB_USERNAME=novasalud
# DB_PASSWORD=
# DB_SOCKET=   # opcional en algunos hostings
#
# Tras cambiar a MySQL: crea la base en el servidor, pon las variables arriba y ejecuta:
#   php artisan migrate --force

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Consultas Perú (CPE API) — consulta DNI: https://docs.consultasperu.com/api-consultas/dni
# Sin token, la búsqueda de paciente solo usa solicitudes previas en la base local.
# CONSULTASPERU_API_TOKEN=
# CONSULTASPERU_API_URL=https://api.consultasperu.com/api/v1/query
# CONSULTASPERU_TIMEOUT=15
