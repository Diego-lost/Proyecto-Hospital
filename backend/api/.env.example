APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Desarrollo conjunto con React: desde la raíz del repo ejecuta `npm run dev` (API en :8000 y Vite en :5173).
# Solo API (`php artisan serve`): sincroniza el build con `npm run public:sync` en la raíz; «Ver sitio web» abre …/public/clinica/ bajo el mismo host que la API.
# Sitio público React (opcional). Ej.: http://localhost/ProyectoNuevo/backend/api/public/clinica/
# Si se omite y APP_URL termina en /backend/api/public, se deduce …/public/clinica/
# FRONTEND_URL=
# Si abres el panel con php artisan serve (:8000), el enlace "Ver sitio web" usa public/clinica o FRONTEND_URL_FALLBACK:
# FRONTEND_URL_FALLBACK=http://127.0.0.1:8000/clinica/

# Panel /admin: credenciales del administrador inicial (php artisan db:seed).
# ADMIN_EMAIL=admin@local.test
# ADMIN_PASSWORD=password
# ADMIN_NAME=Administrador

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local: sqlite (por defecto). Producción / servidor global: MySQL o MariaDB remoto.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=novasalud
# DB_USERNAME=novasalud
# DB_PASSWORD=
# DB_SOCKET=   # opcional en algunos hostings
#
# Tras cambiar a MySQL: crea la base en el servidor, pon las variables arriba y ejecuta:
#   php artisan migrate --force
#
# --- Supabase (PostgreSQL): misma base que el React con VITE_USE_SUPABASE=true ---
# El panel admin y la API deben usar esta conexión para que médicos, especialidades,
# servicios y solicitudes_citas coincidan con lo que ves en Supabase y en el sitio web.
#
# 1) php.ini: extension=pdo_pgsql (reinicia Apache o la CLI).
# 2) Supabase → Project Settings → Database → Connection string.
# 3) DB_SSLMODE=require (casi siempre fuera de la red interna de Supabase).
#
# Si ves "Connection timed out" en Windows (IPv6 / firewall / puerto 5432 bloqueado),
# usa el **Session pooler** (misma pantalla → Mode: Session), no la conexión "Direct":
#   DB_HOST=aws-0-REGION.pooler.supabase.com   (copia el host del panel)
#   DB_PORT=5432
#   DB_USERNAME=postgres.TU_REFERENCIA          (usuario con prefijo del proyecto)
#   DB_PASSWORD=contraseña de BD
# Alternativa pooler transaccional: DB_PORT=6543
#
# Conexión directa (solo si tu red llega a db.xxx.supabase.co:5432):
# DB_CONNECTION=pgsql
# DB_HOST=db.TU_REFERENCIA.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=TU_CONTRASEÑA_DE_BD
# DB_SSLMODE=require
#
# Desarrollo sin Supabase (login/admin con SQLite local; datos distintos al sitio React):
# DB_CONNECTION=sqlite
#
# Si ya ejecutaste supabase/migrations/20260512120000_initial_novasalud.sql, ejecuta igualmente:
#   php artisan migrate
# Las migraciones del catálogo detectan tablas existentes y solo crean users, sessions, jobs, cache, etc.
#
# El SQL de Supabase define ai_interaction_logs.user_id como UUID (auth.users). Laravel guarda el id
# numérico del admin: o bien pones DB_AI_LOG_SKIP_USER_ID=true (los logs IA van con user_id nulo),
# o adaptas esa columna en Postgres a bigint referenciando public.users.
# DB_AI_LOG_SKIP_USER_ID=true
#
# Tras editar .env: php artisan config:clear

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Correos reales (obligatorio para confirmación y reset). Prueba con: php artisan mail:test tu@correo.com
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_USERNAME=72545330@continental.edu.pe
# MAIL_PASSWORD=tu-contraseña-del-correo-institucional
# MAIL_SCHEME=smtp
# MAIL_FROM_ADDRESS="72545330@continental.edu.pe"
# MAIL_FROM_NAME="Clínica NovaSalud"
# Gmail alternativo: MAIL_HOST=smtp.gmail.com + contraseña de aplicación
# Los envíos quedan en email_notifications.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Consulta DNI (nombre) vía Perú API — https://peruapi.com/ (API Key en tu panel).
# PERU_API_KEY=
# PERU_API_BASE_URL=https://peruapi.com
# PERU_API_TIMEOUT=15

# Asistente IA (sugerencia de especialidad). Sin clave, el endpoint responde 503.
# AI_PROVIDER=openai                 # openai | dxgpt
# AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_TIMEOUT=45
# AI_MAX_SUGERENCIAS=3
# AI_JSON_OBJECT_RESPONSE=true
# AI_TRIAGE_ENABLED=true
#
# DxGPT (portal: https://dxgpt-apim.developer.azure-api.net/ — gateway en "Probar")
# Tras cambiar estas variables: npm install --prefix backend/api/scripts
# DXGPT_BASE_URL=https://dxgpt-apim.azure-api.net
# DXGPT_DIAGNOSE_PATH=/api/diagnose
# DXGPT_SUBSCRIPTION_KEY=
# DXGPT_MODEL=gpt4o
# DXGPT_TIMEZONE=America/Lima

# Stripe — pagos en línea (Checkout). Claves en https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # stripe listen --forward-to http://127.0.0.1:8000/api/stripe/webhook
# STRIPE_CURRENCY=pen

# Pagos manuales (Yape / transferencia) — datos mostrados en la pasarela
# PAGOS_YAPE_PHONE=(01) 123-4567
# PAGOS_EMAIL=pagos@novasalud.pe
# PAGOS_BANCO_NOMBRE=Banco de Crédito del Perú (BCP)
# PAGOS_BANCO_CUENTA=191-12345678-0-12
# PAGOS_BANCO_TITULAR=Clínica NovaSalud S.A.C.
# PAGOS_BANCO_CCI=002-191-001234567812-12
# PAGOS_ADMIN_FEE=0

# --- Render (producción) + Firebase Hosting (front en otro dominio) ---
# Despliegue: render.yaml en la raíz del repo (runtime Docker, rootDir backend/api).
# En Render → Environment, copia las variables sensibles de tu .env local (APP_KEY, DB_*, MAIL_*, etc.).
#
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://novasalud-api.onrender.com
# LOG_CHANNEL=stderr
# FRONTEND_URL=https://proyectonuevo-2f2e4.web.app
# CORS_ALLOWED_ORIGINS=https://proyectonuevo-2f2e4.web.app
# CORS_SUPPORTS_CREDENTIALS=true
# SESSION_DRIVER=database
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none
# CACHE_STORE=database
#
# Supabase desde Render: suele funcionar la conexión directa (db.xxx.supabase.co:5432).
# Si falla, usa Session pooler en Supabase → Database → Connection string.
#
# Tras el primer deploy, en apps/web/.env:
#   VITE_API_BASE_URL=https://novasalud-api.onrender.com
# y vuelve a ejecutar en la raíz: npm run deploy:hosting
