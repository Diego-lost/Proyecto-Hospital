# Copia este archivo a `.env` y pon ahí tus valores reales. No subas `.env` a Git.
# En `.env.example` deja solo nombres de variables (sin claves reales).

# API Laravel: obligatoria para **enviar solicitudes de cita** y **Buscar en RENIEC** (el servidor usa PERU_API_KEY).
# El catálogo (especialidades, etc.) puede seguir leyendo desde Supabase si VITE_USE_SUPABASE=true.
# Ej. XAMPP: http://localhost/ProyectoNuevo/backend/api/public  |  artisan serve: http://127.0.0.1:8000
# Si abres …/public/clinica/ con otro host/puerto que esta URL, el front usa el mismo origen que la página.
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Supabase (Dashboard → Project Settings → API): URL + anon public key. La contraseña de BD no va aquí.
# Los valores los escribes en `.env`; aquí solo la plantilla.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_USE_SUPABASE=true

# Pagos Stripe: checkout vía Laravel (STRIPE_* en backend/api/.env). Requiere VITE_API_BASE_URL.
#
# Producción (Firebase + API en Render):
# VITE_API_BASE_URL=https://novasalud-api.onrender.com
